#
# Local MinerU sidecar helper configuration.
#
# This file is consumed by scripts/mineru/install.sh and scripts/mineru/api.sh.
# It is not DlightRAG runtime config. Edit config.yaml for parser_sidecars.*.
#
# Setup:
#   cp .env.mineru.example .env.mineru
#   make mineru-install
#   make mineru-api

# Dedicated MinerU service virtualenv.
MINERU_SERVICE_VENV=.venv-mineru

# MinerU Python extras passed to: uv pip install -U "mineru[$MINERU_INSTALL_EXTRAS]".
# When unset, the installer defaults to core,mlx on Apple Silicon and core
# elsewhere. This template optimizes for local Apple Silicon development.
MINERU_INSTALL_EXTRAS=core,mlx

# Optional exact package version override. Leave unset to install latest.
# MINERU_VERSION=3.2.3

# Cross-platform CPU default:
# MINERU_INSTALL_EXTRAS=core

# GPU/server variants, when supported by the target MinerU release:
# MINERU_INSTALL_EXTRAS=core,vllm
# MINERU_INSTALL_EXTRAS=core,lmdeploy

# Local API bind address. config.yaml defaults parser_sidecars.mineru.local_endpoint
# to http://127.0.0.1:8210, so keep these aligned unless you also update config.yaml.
MINERU_API_HOST=127.0.0.1
MINERU_API_PORT=8210
