{
  "extends": ["stylelint-config-standard"],
  "rules": {
    "selector-class-pattern": "^[a-z][a-zA-Z0-9]*(?:-[a-zA-Z0-9]+)*(?:--[a-zA-Z0-9]+(?:-[a-zA-Z0-9]+)*)?$",
    "declaration-property-value-disallowed-list": {
      "/^font-size$/": ["/^\\d+px/"],
      "/^(padding|margin|gap)$/": ["/^\\d+px/"],
      "/^border-radius$/": ["/^\\d+px/"],
      "/^line-height$/": ["/^(?!var\\()/"]
    }
  }
}
