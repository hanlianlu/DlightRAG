#
# DlightRAG — secrets and deployment-only overrides
#
# Application behavior lives in config.yaml. Keep high-signal product and
# deployment choices there; keep rare tuning in docs/config-reference.md. Use
# this file only for secrets or deployment-specific values that should not be
# committed.
#
# Priority: constructor args > environment variables > .env > config.yaml > defaults

# ─────────────────────────────────────────────────────────────────
# Required model credentials
# ─────────────────────────────────────────────────────────────────

DLIGHTRAG_LLM__DEFAULT__API_KEY=
DLIGHTRAG_EMBEDDING__API_KEY=
DLIGHTRAG_LLM__ROLES__EXTRACT__API_KEY=
DLIGHTRAG_LLM__ROLES__KEYWORD__API_KEY=

# Optional role/provider credentials. Configure the corresponding model/provider
# blocks in config.yaml, then put only the secret here.
# DLIGHTRAG_LLM__ROLES__QUERY__API_KEY=
# DLIGHTRAG_LLM__ROLES__VLM__API_KEY=
# DLIGHTRAG_RERANK__API_KEY=

# ─────────────────────────────────────────────────────────────────
# PostgreSQL credentials
# ─────────────────────────────────────────────────────────────────
# Endpoint settings are in config.yaml. Docker compose also supplies
# local defaults. Override host/user/database in the shell only for deployments
# where config.yaml is mounted read-only.

DLIGHTRAG_POSTGRES_PASSWORD=dlightrag

# ─────────────────────────────────────────────────────────────────
# Parser sidecar secrets
# ─────────────────────────────────────────────────────────────────
# Parser defaults live in config.yaml under parser_sidecars. DlightRAG bridges
# those typed settings into LightRAG's upstream parser environment at startup.
# Only put official API secrets here; leave local MinerU settings in config.yaml.

# DLIGHTRAG_PARSER_SIDECARS__MINERU__API_TOKEN=

# Docker-only deployment override. DlightRAG containers cannot reach a native
# host sidecar through 127.0.0.1, so docker-compose.yml maps this value into the
# app container when an externally managed host MinerU endpoint is used.
# MINERU_DOCKER_LOCAL_ENDPOINT=http://host.docker.internal:8210

# ─────────────────────────────────────────────────────────────────
# API/MCP auth (choose one mode)
# ─────────────────────────────────────────────────────────────────
#
# Mode "none"   — no credentials needed (dev-only, default).
# Mode "simple" — set DLIGHTRAG_AUTH_MODE=simple + DLIGHTRAG_API_AUTH_TOKEN.
#                 Generate with:  openssl rand -base64 32
# Mode "jwt"    — set DLIGHTRAG_AUTH_MODE=jwt + DLIGHTRAG_JWT_SECRET.
#                 Optionally set DLIGHTRAG_JWT_ALGORITHM (default HS256).
#                 Tokens must include a "sub" claim (used as user_id).
#
# All three fields can also be set in config.yaml (under # Security & Auth).

# DLIGHTRAG_AUTH_MODE=simple
# DLIGHTRAG_API_AUTH_TOKEN=
# DLIGHTRAG_JWT_SECRET=
# DLIGHTRAG_JWT_ALGORITHM=HS256

# ─────────────────────────────────────────────────────────────────
# Observability secrets
# ─────────────────────────────────────────────────────────────────
# Configure non-secret Langfuse SDK behavior in config.yaml.

# DLIGHTRAG_LANGFUSE_PUBLIC_KEY=
# DLIGHTRAG_LANGFUSE_SECRET_KEY=

# ─────────────────────────────────────────────────────────────────
# RAGAS evaluation
# ─────────────────────────────────────────────────────────────────
# Used by scripts/ragas_eval.py. The eval LLM and embedding model score
# DlightRAG's answers — they are separate from DlightRAG's own models.
# Only EVAL_LLM_BINDING_API_KEY is required (falls back to OPENAI_API_KEY).
# Full guide: docs/ragas-evaluation.md

# EVAL_LLM_BINDING_API_KEY=
# EVAL_LLM_MODEL=gpt-4o-mini
# EVAL_EMBEDDING_MODEL=text-embedding-3-large
# EVAL_LLM_BINDING_HOST=
# EVAL_EMBEDDING_BINDING_API_KEY=
# EVAL_EMBEDDING_BINDING_HOST=
# EVAL_QUERY_TOP_K=10
# EVAL_MAX_CONCURRENT=2
# EVAL_LLM_MAX_RETRIES=5
# EVAL_LLM_TIMEOUT=180

# DlightRAG connection for eval (only needed when DlightRAG has auth enabled)
# DLIGHTRAG_API_TOKEN=

# ─────────────────────────────────────────────────────────────────
# External data-source secrets
# ─────────────────────────────────────────────────────────────────

# DLIGHTRAG_BLOB_CONNECTION_STRING=
# AWS credentials use the standard AWS_* environment variables.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
# AWS_REGION=
# AWS_DEFAULT_REGION=
