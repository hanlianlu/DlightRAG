#
# DlightRAG — secrets & deployment configuration
# Copy to .env and fill in your values.
#
# Application settings (models, pipeline, storage, etc.) live in config.yaml.
# This file is for secrets and deployment params only in coordination with config.yaml.
#
# Priority: env vars > .env > config.yaml > defaults
#
# ─── Naming convention ──────────────────────────────────────────
# All variables start with DLIGHTRAG_ prefix.
#
#   Single underscore (_) = part of the field name itself
#     DLIGHTRAG_POSTGRES_HOST  →  config.postgres_host
#     DLIGHTRAG_API_PORT       →  config.api_port
#
#   Double underscore (__) = nested object separator (like yaml indentation)
#     DLIGHTRAG_LLM__DEFAULT__API_KEY  →  config.llm.default.api_key
#     DLIGHTRAG_EMBEDDING__API_KEY → config.embedding.api_key
#
# Rule of thumb: __ means "go one level deeper" into a nested object.

# ─────────────────────────────────────────────────────────────────
# API Keys
# ─────────────────────────────────────────────────────────────────

DLIGHTRAG_LLM__DEFAULT__API_KEY=
DLIGHTRAG_EMBEDDING__API_KEY=
# DLIGHTRAG_LLM__ROLES__EXTRACT__API_KEY=     # falls back to llm.default api_key
# DLIGHTRAG_LLM__ROLES__KEYWORD__API_KEY=     # falls back to llm.default api_key
# DLIGHTRAG_LLM__ROLES__QUERY__API_KEY=       # falls back to llm.default api_key
# DLIGHTRAG_LLM__ROLES__VLM__API_KEY=         # falls back to llm.default api_key
# DLIGHTRAG_RERANK__STRATEGY=chat_llm_reranker  # chat_llm_reranker (default), jina_reranker, aliyun_reranker, local_reranker, azure_cohere
# DLIGHTRAG_RERANK__MODEL=                      # optional chat_llm_reranker model override
# DLIGHTRAG_RERANK__BASE_URL=                   # optional override or local_reranker endpoint
# DLIGHTRAG_RERANK__API_KEY=                    # chat_llm_reranker reuses llm.default key unless overridden; required for jina/aliyun/azure
# DLIGHTRAG_CITATIONS__HIGHLIGHTS__ENABLED=false  # optional post-answer UI enrichment
# DLIGHTRAG_CITATIONS__HIGHLIGHTS__TIMEOUT=5.0
# DLIGHTRAG_CITATIONS__HIGHLIGHTS__MAX_CONCURRENCY=4

# ─────────────────────────────────────────────────────────────────
# PostgreSQL (default storage backend)
# ─────────────────────────────────────────────────────────────────

DLIGHTRAG_POSTGRES_HOST=localhost
DLIGHTRAG_POSTGRES_PORT=5432
DLIGHTRAG_POSTGRES_USER=dlightrag
DLIGHTRAG_POSTGRES_PASSWORD=dlightrag
DLIGHTRAG_POSTGRES_DATABASE=dlightrag
DLIGHTRAG_RUNTIME_ROLE=ingest
DLIGHTRAG_POSTGRES_REQUIRED_MAJOR=18

# Role-separated deployment:
#   ingest/admin workers -> primary PostgreSQL
#   query workers        -> hot standby / read replica PostgreSQL
# Set DLIGHTRAG_RUNTIME_ROLE=query on query API workers and configure the
# replica endpoint below. Unset replica fields fall back to primary for local dev.
# DLIGHTRAG_POSTGRES_PRIMARY_HOST=primary.internal
# DLIGHTRAG_POSTGRES_PRIMARY_PORT=5432
# DLIGHTRAG_POSTGRES_PRIMARY_USER=dlightrag
# DLIGHTRAG_POSTGRES_PRIMARY_PASSWORD=dlightrag
# DLIGHTRAG_POSTGRES_PRIMARY_DATABASE=dlightrag
# DLIGHTRAG_POSTGRES_REPLICA_HOST=replica.internal
# DLIGHTRAG_POSTGRES_REPLICA_PORT=5432
# DLIGHTRAG_POSTGRES_REPLICA_USER=dlightrag_reader
# DLIGHTRAG_POSTGRES_REPLICA_PASSWORD=
# DLIGHTRAG_POSTGRES_REPLICA_DATABASE=dlightrag
# DLIGHTRAG_READ_AFTER_WRITE_MODE=eventual
# DLIGHTRAG_READ_AFTER_WRITE_TIMEOUT=15.0

# DlightRAG's core path is PostgreSQL 18 only:
#   pgvector     — LightRAG PGVectorStorage
#   Apache AGE   — LightRAG PGGraphStorage
#   pg_textsearch — DlightRAG BM25 hybrid
# DLIGHTRAG_BM25_ENABLED=true
# DLIGHTRAG_BM25_TOP_K=40
# DLIGHTRAG_BM25_TEXT_CONFIG=simple
# DLIGHTRAG_RRF_K=60
# DLIGHTRAG_METADATA_FILTER_EXACT_VECTOR_THRESHOLD=8192

# ─────────────────────────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────────────────────────

DLIGHTRAG_API_HOST=0.0.0.0
DLIGHTRAG_API_PORT=8100

# Langfuse observability (optional).
# Leave PUBLIC_KEY and SECRET_KEY unset to disable tracing.
# To enable tracing, set both keys from the target Langfuse project.
# This applies to both Langfuse Cloud and local self-hosted Langfuse.
#
# DLIGHTRAG_LANGFUSE_PUBLIC_KEY=pk-...
# DLIGHTRAG_LANGFUSE_SECRET_KEY=sk-...
#
# Langfuse Cloud host options:
# DLIGHTRAG_LANGFUSE_HOST=https://cloud.langfuse.com        # EU Cloud / DlightRAG default
# DLIGHTRAG_LANGFUSE_HOST=https://us.cloud.langfuse.com     # US Cloud
# DLIGHTRAG_LANGFUSE_HOST=https://jp.cloud.langfuse.com     # Japan Cloud
# DLIGHTRAG_LANGFUSE_HOST=https://hipaa.cloud.langfuse.com  # HIPAA Cloud
#
# Local self-host:
# Default path: do not set local project keys by hand. Run `make langfuse-up`.
# That command downloads/prepares ../langfuse-local, syncs the same generated or
# reused API key pair into both env files, then starts Langfuse:
#   ../langfuse-local/.env -> LANGFUSE_INIT_PROJECT_*
#   .env                   -> DLIGHTRAG_LANGFUSE_*
# Only override LANGFUSE_INIT_PROJECT_PUBLIC_KEY/SECRET_KEY before first startup
# if you need deterministic local credentials. Keep the pair identical between
# Langfuse and DlightRAG; use a strong random secret key.
# DLIGHTRAG_LANGFUSE_HOST=http://localhost:3300
#
# DLIGHTRAG_LANGFUSE_EXPORT_EXTERNAL_SPANS=false  # keep false to avoid double-counting auto GenAI spans

# API Authentication configuration (choose one mode)
# 1. Simple Token (Recommended):
# DLIGHTRAG_AUTH_MODE=simple
# DLIGHTRAG_API_AUTH_TOKEN=your_secret_token_here_for_simple_mode
#
# 2. JWT:
# DLIGHTRAG_AUTH_MODE=jwt
# DLIGHTRAG_JWT_SECRET=your_secret_signing_key_here
# DLIGHTRAG_JWT_ALGORITHM=HS256

DLIGHTRAG_MCP_TRANSPORT=stdio
# DLIGHTRAG_MCP_HOST=127.0.0.1   # loopback by default; see warning below
# DLIGHTRAG_MCP_PORT=8101
#
# SECURITY: MCP exposes ingest / answer / delete_files / retrieve over
# streamable-http. The transport has no per-tool auth — when no token is
# set, ANY client able to reach DLIGHTRAG_MCP_HOST:DLIGHTRAG_MCP_PORT can
# wipe all workspaces. Two safe modes:
#   (a) Bind to 127.0.0.1 (default): only local agents can connect.
#   (b) Set DLIGHTRAG_AUTH_MODE=simple + DLIGHTRAG_API_AUTH_TOKEN above
#       AND bind to 0.0.0.0: the MCP transport reuses the same Bearer token.
# The server refuses to start with host=0.0.0.0 + no token.

DLIGHTRAG_LOG_LEVEL=info

# ─────────────────────────────────────────────────────────────────
# External Data Sources (optional)
# ─────────────────────────────────────────────────────────────────

# Azure Blob Storage
# DLIGHTRAG_BLOB_CONNECTION_STRING=

# AWS S3 (uses standard AWS credentials: AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY, AWS_DEFAULT_REGION)
