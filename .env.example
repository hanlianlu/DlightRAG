#
# DlightRAG — secrets and deployment-only overrides
#
# Application behavior lives in config.yaml. Keep high-signal product and
# deployment choices there; keep rare tuning in docs/configuration.md. Use
# this file only for secrets or deployment-specific values that should not be
# committed.
#
# Priority: constructor args > environment variables > .env > config.yaml > defaults

# ─────────────────────────────────────────────────────────────────
# Required model credentials for the checked-in config.yaml
# ─────────────────────────────────────────────────────────────────

DLIGHTRAG_LLM__DEFAULT__API_KEY=
DLIGHTRAG_EMBEDDING__API_KEY=
DLIGHTRAG_LLM__ROLES__EXTRACT__API_KEY=
DLIGHTRAG_LLM__ROLES__KEYWORD__API_KEY=
DLIGHTRAG_RERANK__API_KEY=

## Role credentials are needed only for role blocks you configure. The checked-in
## config.yaml configures extract/keyword roles and Voyage reranking. If you remove
## those role blocks or switch rerank back to chat_llm_reranker, the corresponding
## role/rerank keys can be omitted.

# DLIGHTRAG_LLM__ROLES__QUERY__API_KEY=
# DLIGHTRAG_LLM__ROLES__VLM__API_KEY=

# ─────────────────────────────────────────────────────────────────
# PostgreSQL credentials
# ─────────────────────────────────────────────────────────────────
## Endpoint settings are in config.yaml. Docker compose also supplies local defaults. 

DLIGHTRAG_POSTGRES_PASSWORD=dlightrag

# ─────────────────────────────────────────────────────────────────
# OPTIONAL: Only set if you configure official MINERU API access in config.yaml
# ─────────────────────────────────────────────────────────────────

# DLIGHTRAG_PARSER_SIDECARS__MINERU__API_TOKEN=

# ─────────────────────────────────────────────────────────────────
# OPTIONAL: API/MCP auth (default is "none")
# ─────────────────────────────────────────────────────────────────

## Mode "none"   — no credentials needed (dev-only, default).
## Mode "simple" — set DLIGHTRAG_AUTH_MODE=simple + DLIGHTRAG_API_AUTH_TOKEN.
##                 Generate with:  openssl rand -base64 32
## Mode "jwt"    — set DLIGHTRAG_AUTH_MODE=jwt + DLIGHTRAG_JWT_VERIFICATION_KEY.
##                 Optionally set DLIGHTRAG_JWT_ALGORITHM (default HS256 for HMAC, RS256 for RSA).
##                 Tokens must include a "sub" claim (used as user_id).
## All three fields can also be set in config.yaml (under # Security & Auth).

# DLIGHTRAG_AUTH_MODE=simple
# DLIGHTRAG_API_AUTH_TOKEN=
# DLIGHTRAG_JWT_VERIFICATION_KEY=
# DLIGHTRAG_JWT_ALGORITHM=HS256

# ─────────────────────────────────────────────────────────────────
# OPTIONAL: Observability secrets - Configure non-secret Langfuse SDK behavior in config.yaml
# ─────────────────────────────────────────────────────────────────
## For local development, `make langfuse-up` runs a bundled Langfuse stack and
## fills these two keys for you (synced with the local stack). See docs/
## operations.md "Local Langfuse Observability". Set them by hand only for an
## external/cloud Langfuse. Both keys are required or tracing stays off. The
## non-secret endpoint (langfuse_host) lives in config.yaml, not here.

# DLIGHTRAG_LANGFUSE_PUBLIC_KEY=
# DLIGHTRAG_LANGFUSE_SECRET_KEY=

# ─────────────────────────────────────────────────────────────────
# OPTIONAL: RAGAS evaluation (auto-resolves from DlightRAG config)
# ─────────────────────────────────────────────────────────────────
## scripts/ragas_eval.py scores DlightRAG answers with RAGAS. All eval
## credentials auto-resolve from DlightRAG's own LLM/embedding config,
## so no extra .env entries are needed in the common case.
## Only uncomment below to override the auto-resolved values.
## Full guide: docs/evaluation.md

# EVAL_LLM_MODEL=
# EVAL_LLM_BINDING_API_KEY=
# EVAL_LLM_BINDING_HOST=
# EVAL_EMBEDDING_MODEL=
# EVAL_EMBEDDING_BINDING_API_KEY=
# EVAL_EMBEDDING_BINDING_HOST=
# EVAL_QUERY_TOP_K=10
# EVAL_MAX_CONCURRENT=2
# EVAL_LLM_MAX_RETRIES=5
# EVAL_LLM_TIMEOUT=180

# ─────────────────────────────────────────────────────────────────
# OPTIONAL: External data-source secrets
# ─────────────────────────────────────────────────────────────────

# DLIGHTRAG_BLOB_CONNECTION_STRING=

## AWS credentials use the standard AWS_* environment variables.

# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
# AWS_REGION=
# AWS_DEFAULT_REGION=
